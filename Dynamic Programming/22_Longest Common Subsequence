class Solution {
public:
    int helper(int idx1,int idx2,string text1, string text2,int l1,int l2)
    {
       if(idx1<0 || idx2<0) return 0;
       
       if(text1[idx1]==text2[idx2])
       {
          return 1 + helper(idx1-1,idx2-1,text1,text2,l1,l2);
       }

       return max(helper(idx1-1,idx2,text1,text2,l1,l2),helper(idx1,idx2-1,text1,text2,l1,l2));
    }
    int longestCommonSubsequence(string text1, string text2) 
    {
        int l1=text1.length();
        int l2=text2.length();

        return helper(l1-1,l2-1,text1,text2,l1,l2);
    }
};


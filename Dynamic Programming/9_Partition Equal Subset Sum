//https://leetcode.com/problems/partition-equal-subset-sum/description/

same as prev prob

class Solution {
public:
    bool helper(int idx,vector<int>& nums,int target)
    {
       if(idx<0) return false;
       if(target==0) return true;
       if(idx==0) return target==nums[0];

       bool notpick = helper(idx-1,nums,target);
       bool pick=false;
       if(nums[idx]<=target)
       {
          pick = helper(idx-1,nums,target-nums[idx]);
       }
       return pick || notpick;
    }
    bool canPartition(vector<int>& nums) 
    {
        int n=nums.size();
        int sum=0;
        for(auto ele:nums) sum += ele;
        if(sum%2 !=0) return false;
        int target = sum/2;

        return helper(n-1,nums,target);
    }
};

class Solution {
public:
    bool helper(int idx,vector<int>& nums,int target,vector<vector<int>>& dp)
    {
       if(idx<0) return false;
       if(target==0) return dp[idx][target] = true;
       if(idx==0) return dp[idx][target] = ( target==nums[0] );

       if(dp[idx][target] != -1) return dp[idx][target];

       bool notpick = helper(idx-1,nums,target,dp);
       bool pick=false;
       if(nums[idx]<=target)
       {
          pick = helper(idx-1,nums,target-nums[idx],dp);
       }
       return dp[idx][target] = pick || notpick;
    }
    bool canPartition(vector<int>& nums) 
    {
        int n=nums.size();
        int sum=0;
        for(auto ele:nums) sum += ele;
        if(sum%2 !=0) return false;
        int target = sum/2;
        vector<vector<int>> dp(n,vector<int>(target+1,-1));

        return helper(n-1,nums,target,dp);
    }
};


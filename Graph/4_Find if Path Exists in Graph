//https://leetcode.com/problems/find-if-path-exists-in-graph/description/

class Solution {
public:
    void dfs(int node,vector<bool>& visited,vector<int> adjList[])
    {
         visited[node]=true;
         for(auto it:adjList[node])
         {
            if(!visited[it])
            {
                dfs(it,visited,adjList);
            }
         }
    }
    bool validPath(int n, vector<vector<int>>& edges, int source, int destination) 
    {
        vector<int> adjList[n];
        vector<bool> visited(n,false);
        for(int i=0;i<edges.size();i++)
        {
            int u = edges[i][0];
            int v = edges[i][1];
            adjList[u].push_back(v);
            adjList[v].push_back(u);
        }

        dfs(source,visited,adjList);
        return visited[destination];
    }
};

Time:
Building Adjacency List:
You process each edge once
👉 O(E)

DFS Traversal:
Each node visited once → O(V)
Each edge explored once → O(E)

total time: O(E) + O(V + E) = O(V + E)

Space Complexity: O(V + E)
Adjacency List Stores all edges → O(V + E)
Visited Array : o(V)

***recursion***
#include <bits/stdc++.h> 
bool helper(int idx,vector<int> &arr,int n,int target)
{
   //base case
   if(target == 0) return true;
   if(idx == 0) return arr[idx]==target;
   
   bool notpick = helper(idx-1,arr,n,target);

   bool pick = false;
   if(target>=arr[idx])
   {
      pick = helper(idx-1,arr,n,target-arr[idx]);
   }
   return pick || notpick;
}
bool subsetSumToK(int n, int k, vector<int> &arr) 
{
    return helper(n-1,arr,n,k);
}

*********memoization****
#include <bits/stdc++.h> 
bool helper(int idx,vector<int> &arr,int n,int target,
            vector<vector<int>>& dp)
{
   //base case
   if(target == 0) return true;
   if(idx == 0) return arr[idx]==target;
   
   if(dp[idx][target] != -1)
   {
      return dp[idx][target];
   }
   bool notpick = helper(idx-1,arr,n,target,dp);

   bool pick = false;
   if(target>=arr[idx])
   {
      pick = helper(idx-1,arr,n,target-arr[idx],dp);
   }
   return dp[idx][target] = pick || notpick;
}
bool subsetSumToK(int n, int k, vector<int> &arr) 
{
   vector<vector<int>> dp(n+1,vector<int>(k+1,-1));
   return helper(n-1,arr,n,k,dp);
}



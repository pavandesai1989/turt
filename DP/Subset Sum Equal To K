class Solution {
  public:
    bool isSubsetSum(vector<int>& arr, int k) 
    {
        int n=arr.size();
        vector<vector<int>> dp(n,vector<int>(k+1,0));
       //base case is if target 0 return treu
       for(int i=0;i<n;i++)
       {
          dp[i][0]=1;
       }

       // arr = [8,3,4]  k = 6  if not there? it tries to access dp[0][8] causing excpetion******
       if(arr[0]<=k)  ///vimp check use case  
          dp[0][arr[0]] = 1;
    
       for(int i=1;i<n;i++)
       {
          for(int tar=1;tar<=k;tar++)
          {
             bool notpick = dp[i-1][tar];
             bool pick = false;
             if(arr[i]<=tar)
             {
                pick = dp[i-1][tar-arr[i]];
             }
    
             dp[i][tar] = pick || notpick;
          }
       }
    
       return dp[n-1][k];
        
    }
};
